# ==============================================================================
# Production Environment Variables
# ==============================================================================
# DO NOT create or commit .env.prod file to git
# ALWAYS use AWS Secrets Manager for production secrets
# ==============================================================================
# This is a template showing what variables are expected in production
# Use: aws secretsmanager get-secret-value --secret-id myproject/prod
# ==============================================================================

ENVIRONMENT=production
PROJECT_NAME=myproject
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=WARN

# Backend Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=false
BACKEND_WORKERS=8
API_TITLE=MyProject API
API_DESCRIPTION=Production Environment
API_VERSION=1.0.0

# Database - AWS RDS (Multi-AZ)
DATABASE_USER=postgres
DATABASE_PASSWORD=*** USE SECRETS MANAGER ***
DATABASE_HOST=rds-prod.xxx.us-east-1.rds.amazonaws.com
DATABASE_PORT=5432
DATABASE_NAME=myproject_prod
DATABASE_POOL_SIZE=30
DATABASE_MAX_OVERFLOW=15
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=false

# Security - STRONG RANDOM KEYS ONLY
JWT_SECRET_KEY=*** USE SECRETS MANAGER ***
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# CORS - Production
ALLOWED_ORIGINS=https://myproject.com,https://www.myproject.com
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_HEADERS=Content-Type,Authorization

# Security Headers - Full enforcement
ENABLE_HTTPS_REDIRECT=true
ENABLE_HSTS=true
HSTS_MAX_AGE=31536000
SECURE_COOKIES=true

# Frontend
FRONTEND_URL=https://myproject.com
API_BASE_URL=https://api.myproject.com

# Logging - JSON to CloudWatch
LOG_FORMAT=json
LOG_OUTPUT=console
LOG_FILE_PATH=/var/log/app

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=*** USE IAM ROLE ***
AWS_SECRET_ACCESS_KEY=*** USE IAM ROLE ***
AWS_SECRETS_MANAGER_SECRET_NAME=myproject/prod

# Monitoring - Production
SENTRY_DSN=*** USE SECRETS MANAGER ***
DATADOG_API_KEY=*** USE SECRETS MANAGER ***
ENABLE_METRICS=true
METRICS_PORT=9090

# Rate Limiting - Strict for production
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=50
RATE_LIMIT_WINDOW_SECONDS=60
