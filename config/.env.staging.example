# ==============================================================================
# Staging Environment Configuration - Example Template
# ==============================================================================
# Use this file as a reference for STAGING values.
# Manage sensitive values via GitHub Secrets or AWS Secrets Manager.
# ==============================================================================

ENVIRONMENT=staging
PROJECT_NAME=myproject
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Backend Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=false
BACKEND_WORKERS=4
API_TITLE=MyProject API
API_DESCRIPTION=Staging Environment
API_VERSION=1.0.0

# Database - non-secret connection config (password from GitHub secret)
DATABASE_USER=postgres
DATABASE_HOST=rds-staging.xxx.us-east-1.rds.amazonaws.com
DATABASE_PORT=5432
DATABASE_NAME=myproject_staging
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=false

# Security - algorithm and expiry only (JWT key from GitHub secret)
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=https://staging.myproject.com
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_HEADERS=Content-Type,Authorization

# Security Headers
ENABLE_HTTPS_REDIRECT=true
ENABLE_HSTS=true
HSTS_MAX_AGE=31536000
SECURE_COOKIES=true

# Frontend
FRONTEND_URL=https://staging.myproject.com
API_BASE_URL=https://api-staging.myproject.com

# Logging
LOG_FORMAT=json
LOG_OUTPUT=console
LOG_FILE_PATH=/var/log/app

# AWS
AWS_REGION=us-east-1
AWS_SECRETS_MANAGER_SECRET_NAME=myproject/staging

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# CI/CD Workflow Tooling
REGISTRY=ghcr.io
TF_VERSION=1.5.0
PROJECT_ROOT=.
