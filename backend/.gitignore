# ============================================================================
# Backend-specific Python .gitignore
# ============================================================================
# This is supplementary to the root .gitignore
# ============================================================================

# ============================================================================
# Environment & Secrets
# ============================================================================
.env
.env.local
.env.*.local

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.pytest_cache/
.mypy_cache/
.coverage
coverage.xml
htmlcov/
dist/
build/
*.egg-info/
.eggs/
.venv/
.ruff_cache/

# ============================================================================
# Database & Cache
# ============================================================================
alembic/__pycache__/*
alembic/versions/__pycache__/*
tests/__pycache__/*
test.db
*.sqlite
*.sqlite3

# ============================================================================
# IDE
# ============================================================================
.idea
.vscode/
*.code-workspace

# ============================================================================
# OS & Temp
# ============================================================================
.DS_Store
*.swp
*.swo
*~
.tmp/
.pytest_cache/

# ============================================================================
# Logs
# ============================================================================
*.log
logs/