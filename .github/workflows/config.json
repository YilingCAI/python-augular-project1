{
    "environments": {
        "dev": {
            "aws_region": "us-east-1",
            "terraform_backend_key": "dev/terraform.tfstate",
            "ecs_cluster": "mypythonproject1-cluster-dev",
            "vpc_cidr": "10.0.0.0/16",
            "log_retention_days": 7,
            "enable_container_insights": true,
            "auto_approve": false,
            "approval_required": false
        },
        "staging": {
            "aws_region": "us-east-1",
            "terraform_backend_key": "staging/terraform.tfstate",
            "ecs_cluster": "mypythonproject1-cluster-staging",
            "vpc_cidr": "10.1.0.0/16",
            "log_retention_days": 30,
            "enable_container_insights": true,
            "auto_approve": false,
            "approval_required": false
        },
        "prod": {
            "aws_region": "us-east-1",
            "terraform_backend_key": "prod/terraform.tfstate",
            "ecs_cluster": "mypythonproject1-cluster-prod",
            "vpc_cidr": "10.2.0.0/16",
            "log_retention_days": 90,
            "enable_container_insights": true,
            "auto_approve": false,
            "approval_required": true
        }
    },
    "security": {
        "trivy_severity": [
            "CRITICAL",
            "HIGH"
        ],
        "bandit_severity": "HIGH",
        "sast_enabled": true,
        "secret_scanning_enabled": true,
        "dependency_scanning_enabled": true,
        "container_scanning_enabled": true
    },
    "terraform": {
        "version": "1.5.0",
        "fmt_check": true,
        "lock_table": "terraform-locks",
        "state_bucket": "terraform-state-prod"
    },
    "deployment": {
        "blue_green_enabled": true,
        "health_check_timeout": 600,
        "auto_rollback_enabled": true,
        "smoke_tests_enabled": true,
        "require_manual_approval": {
            "staging": false,
            "prod": true
        }
    }
}